<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="400dp"
    android:height="80dp"
    android:viewportWidth="400"
    android:viewportHeight="80">

    <!-- The Glow Effect -->
    <path
        android:pathData="M0,80 Q200,10 400,80 L400,80 L0,80 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="200"
                android:centerY="40"
                android:gradientRadius="200"
                android:type="radial">
                <item android:color="#402BB673" android:offset="0" />
                <item android:color="#002BB673" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- The Curved Green Line -->
    <path
        android:pathData="M0,80 Q200,10 400,80"
        android:strokeWidth="3"
        android:strokeColor="#2BB673"
        android:strokeLineCap="round" />

</vector>